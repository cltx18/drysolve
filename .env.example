# DrySolve Restoration - Environment Variables

# Server
PORT=3000
NODE_ENV=production

# Database (Railway: use the volume mount path)
DB_PATH=/data/drysolve.db

# Twilio
TWILIO_PHONE=+17207706366

# Admin
ADMIN_PASSWORD=ChangeThisToSomethingStrong!
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# GoHighLevel Webhooks (optional but recommended)
GHL_LEAD_WEBHOOK=https://services.leadconnectorhq.com/hooks/your-lead-webhook-here
GHL_FRANCHISE_WEBHOOK=https://services.leadconnectorhq.com/hooks/your-franchise-webhook-here
